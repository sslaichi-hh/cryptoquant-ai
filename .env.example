# OKX live trading API credentials
OKX_API_KEY=YOUR_OKX_API_KEY_HERE
OKX_SECRET_KEY=YOUR_OKX_SECRET_KEY_HERE
OKX_PASSPHRASE=YOUR_OKX_PASSPHRASE_HERE

# OKX demo trading API credentials
OKX_DEMO_API_KEY=YOUR_OKX_DEMO_API_KEY_HERE
OKX_DEMO_SECRET_KEY=YOUR_OKX_DEMO_SECRET_KEY_HERE
OKX_DEMO_PASSPHRASE=YOUR_OKX_DEMO_PASSPHRASE_HERE

# Local encrypted credential store
# Use a long random value in real deployments.
APP_SECRET=YOUR_LONG_RANDOM_APP_SECRET_HERE

# Local operator authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD_HERE
SESSION_TTL_HOURS=12

# Optional exchange proxy for CCXT/OKX requests.
# Example: http://127.0.0.1:10808
EXCHANGE_PROXY_URL=

# Zhipu AI configuration
ZHIPU_API_KEY=YOUR_ZHIPU_API_KEY_HERE
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
ZHIPU_DECISION_MODEL=glm-4.5-air
ZHIPU_SUMMARY_MODEL=glm-4.5-air
ZHIPU_VISION_MODEL=glm-4.6v

# Macro data API
FRED_API_KEY=YOUR_FRED_API_KEY_HERE

# Optional email notifications
SMTP_USER=YOUR_SMTP_USER_HERE
SMTP_PASS=YOUR_SMTP_PASSWORD_HERE
SMTP_TO=YOUR_NOTIFICATION_EMAIL_HERE
